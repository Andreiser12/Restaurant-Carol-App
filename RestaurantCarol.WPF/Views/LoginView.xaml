<Window x:Class="RestaurantCarol.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RestaurantCarol.ViewModels"
        Title="Restaurant Carol - Autentificare" 
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Images/carol_background.jpg" 
                        Stretch="UniformToFill"
                        Opacity="0.7"/>
        </Grid.Background>

        <Border Background="#EB7A6B14"
                CornerRadius="8"
                Width="500"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Padding="40,30,40,30">

            <StackPanel HorizontalAlignment="Center">

                <TextBlock x:Name="titluText"
                           Text="Intra in cont"
                           FontSize="28"
                           FontWeight="Light"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <TextBlock Text="Email:" 
                           Foreground="White"
                           FontSize="14"
                           Margin="0,0,0,5"/>
                <TextBox Width="350" Height="35" 
                         FontSize="14"
                         Padding="8,5,8,5"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Parola:" 
                           Foreground="White"
                           FontSize="14"
                           Margin="0,15,0,5"/>
                <PasswordBox x:Name="passwordBox"
                             Width="350" Height="35" 
                             FontSize="14"
                             Padding="8,5,8,5"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <Button Content="Autentificare" 
                        Width="200" Height="40"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Background="#F4B860"
                        Foreground="#3A3A3A"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,30,0,0"
                        Command="{Binding LoginCommand}"/>

                <Button Content="Inapoi" 
                        Width="200" Height="35"
                        FontSize="14"
                        Background="Transparent"
                        Foreground="White"
                        BorderBrush="White"
                        BorderThickness="1"
                        Cursor="Hand"
                        Margin="0,15,0,0"
                        Click="Inapoi_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>