<UserControl x:Class="RestaurantCarol.Views.HubUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="CircleButton" TargetType="Button">
            <Setter Property="Width" Value="280"/>
            <Setter Property="Height" Value="280"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="ellipse"
                                 Stroke="#3A3A3A" 
                                 StrokeThickness="3"/>
                            <ContentPresenter HorizontalAlignment="Stretch" 
                                          VerticalAlignment="Stretch"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ellipse" Property="Opacity" Value="0.8"/>
                                <Setter TargetName="ellipse" Property="StrokeThickness" Value="5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Width="220" Height="220"
                CornerRadius="110"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                ClipToBounds="True">
            <Border.Background>
                <ImageBrush ImageSource="/Images/carol_logo.png" 
                            Stretch="UniformToFill"/>
            </Border.Background>
        </Border>

        <UniformGrid Grid.Row="1" 
             Rows="1" Columns="3"
             HorizontalAlignment="Stretch"
             Margin="50,0,50,40">

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom">
                <Button Style="{StaticResource CircleButton}"
                Click="Populare_Click">
                    <Border Width="280" Height="280" 
                    CornerRadius="140"
                    ClipToBounds="True">
                        <Border.Background>
                            <ImageBrush ImageSource="/Images/categorie_populare.png" 
                                Stretch="UniformToFill"/>
                        </Border.Background>
                    </Border>
                </Button>
                <TextBlock Text="Cele mai populare" 
                   TextAlignment="Center"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="White"
                   Margin="0,15,0,0"
                   HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="8" 
                                  ShadowDepth="2" Opacity="0.8"/>
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom">
                <Button Style="{StaticResource CircleButton}"
                Click="Mancare_Click">
                    <Border Width="280" Height="280" 
                    CornerRadius="140"
                    ClipToBounds="True">
                        <Border.Background>
                            <ImageBrush ImageSource="/Images/categorie_mancare.png" 
                                Stretch="UniformToFill"/>
                        </Border.Background>
                    </Border>
                </Button>
                <TextBlock Text="Mancare" 
                   TextAlignment="Center"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="White"
                   Margin="0,15,0,0"
                   HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="8" 
                                  ShadowDepth="2" Opacity="0.8"/>
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom">
                <Button Style="{StaticResource CircleButton}"
                Click="Bauturi_Click">
                    <Border Width="280" Height="280" 
                    CornerRadius="140"
                    ClipToBounds="True">
                        <Border.Background>
                            <ImageBrush ImageSource="/Images/categorie_bauturi.png" 
                                Stretch="UniformToFill"/>
                        </Border.Background>
                    </Border>
                </Button>
                <TextBlock Text="Bauturi" 
                   TextAlignment="Center"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="White"
                   Margin="0,15,0,0"
                   HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="8" 
                                  ShadowDepth="2" Opacity="0.8"/>
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>

        </UniformGrid>
    </Grid>
</UserControl>