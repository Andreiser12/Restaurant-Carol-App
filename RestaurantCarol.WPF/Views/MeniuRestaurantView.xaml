<Window x:Class="RestaurantCarol.Views.MeniuRestaurantView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Restaurant Carol - Meniu" 
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <Style x:Key="HeaderPanel" TargetType="Border">
            <Setter Property="Background" Value="#EB3A3A3A"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="15,10,15,10"/>
            <Setter Property="Margin" Value="5,0,5,0"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="HeaderWelcome" TargetType="Border">
            <Setter Property="Background" Value="#EB7A6B14"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="30,12,30,12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Images/interior_background.jpg" 
                        Stretch="UniformToFill"
                        Opacity="0.7"/>
        </Grid.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
        Background="#EB3A3A3A"
        CornerRadius="0"
        Margin="0"
        Height="110">
                <Grid Margin="20,0,20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                x:Name="puncteBorder"
                Background="#EB7A6B14"
                CornerRadius="6"
                Padding="20,10,20,10"
                VerticalAlignment="Center"
                Visibility="Collapsed">
                        <TextBlock x:Name="puncteText"
                       Text="Puncte Carol: 0"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="White"
                       VerticalAlignment="Center"/>
                    </Border>

                    <Border Grid.Column="1" 
                Background="#EB7A6B14"
                CornerRadius="6"
                Padding="30,12,30,12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                        <TextBlock Text="Bine ai venit la Carol!"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="White"
                       VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    x:Name="panouDreapta">
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="40,20,40,40">
                <ContentControl x:Name="contentArea"/>
            </Grid>
        </Grid>
    </Grid>
</Window>