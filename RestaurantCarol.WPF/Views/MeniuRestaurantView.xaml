<Window x:Class="RestaurantCarol.Views.MeniuRestaurantView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Restaurant Carol - Meniu" 
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <Style x:Key="SidePanelButton" TargetType="Button">
            <Setter Property="Background" Value="#F4B860"/>
            <Setter Property="Foreground" Value="#3A3A3A"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Width" Value="180"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoPanel" TargetType="Border">
            <Setter Property="Background" Value="#EBF4B860"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="15,10,15,10"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="Width" Value="180"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Images/interior_background.jpg" 
                        Stretch="UniformToFill"
                        Opacity="0.7"/>
        </Grid.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="40,20,40,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="1" 
                        Background="#EB7A6B14"
                        CornerRadius="6"
                        Padding="30,12,30,12">
                    <TextBlock Text="Bine ai venit la Carol!"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                </Border>

                <Border Grid.Column="2" 
                        Background="#EB7A6B14"
                        CornerRadius="6"
                        Padding="20,12,20,12"
                        HorizontalAlignment="Right">
                    <TextBlock x:Name="prenumeText"
                               Text="Oaspete"
                               FontSize="18"
                               Foreground="White"/>
                </Border>
            </Grid>

            <Grid Grid.Row="1" Margin="40,20,40,40">

                <ContentControl x:Name="contentArea"/>

                <StackPanel x:Name="panouDreapta"
                VerticalAlignment="Top"
                HorizontalAlignment="Right">
                </StackPanel>

            </Grid>
        </Grid>
    </Grid>
</Window>