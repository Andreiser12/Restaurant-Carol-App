<Window x:Class="RestaurantCarol.Views.MeniuRestaurantView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Restaurant Carol - Meniu" 
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <Style x:Key="HeaderPanel" TargetType="Border">
            <Setter Property="Background" Value="#EB3A3A3A"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="15,10,15,10"/>
            <Setter Property="Margin" Value="5,0,5,0"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="HeaderButton" TargetType="Button">
            <Setter Property="Background" Value="#F4B860"/>
            <Setter Property="Foreground" Value="#3A3A3A"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="5,0,5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderPanelTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#D2AF6D"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="HeaderPanelSubtitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#D2AF6D"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Images/interior_background.jpg" 
                        Stretch="UniformToFill"
                        Opacity="0.7"/>
        </Grid.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
                    Background="#EB3A3A3A"
                    CornerRadius="0"
                    Margin="0"
                    Height="110">
                <Grid Margin="20,0,20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#EB7A6B14"
                            CornerRadius="6"
                            Padding="20,10,20,10"
                            VerticalAlignment="Center"
                            Visibility="{Binding VizibilitatePuncte}">
                        <TextBlock Text="{Binding PuncteText}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <Border Grid.Column="1" 
                            Background="#EB7A6B14"
                            CornerRadius="6"
                            Padding="30,12,30,12"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <TextBlock Text="Bine ai venit la Carol!"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <Grid Grid.Column="2"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center">

                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding VizibilitatePanouClient}">

                            <Border Style="{StaticResource HeaderPanel}">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" 
                                                  Command="{Binding CosCommand}"/>
                                </Border.InputBindings>
                                <StackPanel>
                                    <TextBlock Text="COS" Style="{StaticResource HeaderPanelTitle}"/>
                                    <TextBlock Text="{Binding CosCountText}" 
                                               Style="{StaticResource HeaderPanelSubtitle}"/>
                                    <TextBlock Text="{Binding CosTotalText}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#D2AF6D"
                                               HorizontalAlignment="Center"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource HeaderPanel}">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" 
                                                  Command="{Binding AdresaCommand}"/>
                                </Border.InputBindings>
                                <StackPanel>
                                    <TextBlock Text="ADRESA" Style="{StaticResource HeaderPanelTitle}"/>
                                    <TextBlock Text="{Binding AdresaText}"
                                               FontSize="11"
                                               Foreground="#D2AF6D"
                                               TextWrapping="Wrap"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               Margin="0,5,0,0"
                                               MaxWidth="150"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource HeaderPanel}">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" 
                                                  Command="{Binding StareComandaCommand}"/>
                                </Border.InputBindings>
                                <StackPanel>
                                    <TextBlock Text="STARE COMANDA" Style="{StaticResource HeaderPanelTitle}"/>
                                    <TextBlock Text="{Binding StareCmdCodText}"
                                               FontSize="10"
                                               Foreground="#D2AF6D"
                                               HorizontalAlignment="Center"
                                               Margin="0,5,0,0"/>
                                    <TextBlock Text="{Binding StareCmdStareText}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="#D2AF6D"
                                               HorizontalAlignment="Center"
                                               Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding StareCmdOraText}"
                                               FontSize="10"
                                               FontStyle="Italic"
                                               Foreground="#D2AF6D"
                                               HorizontalAlignment="Center"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <Grid>
                                <Border x:Name="prenumeBorder"
                                        Background="#EB7A6B14"
                                        CornerRadius="6"
                                        Padding="20,12,20,12"
                                        Margin="5,0,0,0"
                                        Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" 
                                                      Command="{Binding PrenumeCommand}"/>
                                    </Border.InputBindings>
                                    <TextBlock Text="{Binding PrenumeText}"
                                               FontSize="18"
                                               Foreground="White"/>
                                </Border>

                                <Popup IsOpen="{Binding PopupPrenumeDeschis, Mode=TwoWay}"
                                       PlacementTarget="{Binding ElementName=prenumeBorder}"
                                       Placement="Bottom"
                                       StaysOpen="False"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade">
                                    <Border Background="White"
                                            CornerRadius="8"
                                            Margin="5,8,5,8"
                                            MinWidth="160">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" BlurRadius="15"
                                                              ShadowDepth="0" Opacity="0.3"/>
                                        </Border.Effect>
                                        <StackPanel>
                                            <Button Content="Iesire din cont"
                                                    Background="Transparent"
                                                    Foreground="#D85A4A"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    BorderThickness="0"
                                                    Padding="20,12,20,12"
                                                    HorizontalContentAlignment="Left"
                                                    Cursor="Hand"
                                                    Command="{Binding LogoutCommand}"/>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>

                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding VizibilitatePanouOaspete}">

                            <Button Style="{StaticResource HeaderButton}"
                                    Content="Logheaza-te"
                                    Command="{Binding LoginCommand}"/>

                            <Button Style="{StaticResource HeaderButton}"
                                    Content="Inregistreaza-te"
                                    Command="{Binding RegisterCommand}"/>

                            <Border Background="#EB7A6B14"
                                    CornerRadius="6"
                                    Padding="20,12,20,12"
                                    Margin="5,0,0,0">
                                <TextBlock Text="{Binding PrenumeText}"
                                           FontSize="18"
                                           Foreground="White"/>
                            </Border>

                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="40,20,40,40">
                <ContentControl x:Name="contentArea"/>
            </Grid>
        </Grid>
    </Grid>
</Window>