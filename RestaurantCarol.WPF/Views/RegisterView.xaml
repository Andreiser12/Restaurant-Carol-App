<Window x:Class="RestaurantCarol.Views.RegisterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RestaurantCarol.ViewModels"
        Title="Restaurant Carol - Inregistrare" 
        Height="700" Width="800"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Images/carol_background.jpg" 
                        Stretch="UniformToFill"
                        Opacity="0.7"/>
        </Grid.Background>

        <ScrollViewer VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled">
            <Border Background="#373334"
                    CornerRadius="8"
                    Width="500"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="40,30,40,30"
                    Margin="0,30,0,30">

                <StackPanel HorizontalAlignment="Center">

                    <TextBlock Text="Creeaza un cont nou"
                               FontSize="26"
                               FontWeight="Light"
                               Foreground="#D2AF6D"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,25"/>

                    <TextBlock Text="Nume:" 
                               Foreground="#D2AF6D" FontSize="14" Margin="0,0,0,5"/>
                    <TextBox Width="350" Height="32" FontSize="14" Padding="8,5,8,5"
                             Text="{Binding Nume, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Prenume:" 
                               Foreground="#D2AF6D" FontSize="14" Margin="0,12,0,5"/>
                    <TextBox Width="350" Height="32" FontSize="14" Padding="8,5,8,5"
                             Text="{Binding Prenume, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Email:" 
                               Foreground="#D2AF6D" FontSize="14" Margin="0,12,0,5"/>
                    <TextBox Width="350" Height="32" FontSize="14" Padding="8,5,8,5"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Telefon:" 
                               Foreground="#D2AF6D" FontSize="14" Margin="0,12,0,5"/>
                    <TextBox Width="350" Height="32" FontSize="14" Padding="8,5,8,5"
                             Text="{Binding Telefon, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Adresa de livrare:" 
                               Foreground="#D2AF6D" FontSize="14" Margin="0,12,0,5"/>
                    <TextBox Width="350" Height="60" FontSize="14" Padding="8,5,8,5"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding AdresaLivrare, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Parola (minim 6 caractere):" 
                               Foreground="#D2AF6D" FontSize="14" Margin="0,12,0,5"/>
                    <PasswordBox x:Name="passwordBox"
                                 Width="350" Height="32" FontSize="14" Padding="8,5,8,5"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>

                    <TextBlock Text="Confirma parola:" 
                               Foreground="#D2AF6D" FontSize="14" Margin="0,12,0,5"/>
                    <PasswordBox x:Name="confirmPasswordBox"
                                 Width="350" Height="32" FontSize="14" Padding="8,5,8,5"
                                 PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>

                    <Button Content="Inregistreaza-ma" 
                            Width="220" Height="40"
                            FontSize="16" FontWeight="SemiBold"
                            Background="#D2AF6D" Foreground="#373334"
                            BorderThickness="0" Cursor="Hand"
                            Margin="0,25,0,0"
                            Command="{Binding RegisterCommand}"/>

                    <Button Content="Inapoi" 
                            Width="220" Height="40"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Background="#D2AF6D"
                            Foreground="#373334"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,15,0,0"
                            Click="Inapoi_Click"/>

                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>