<Window x:Class="RestaurantCarol.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Restaurant Carol" 
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="#D2AF6D"/>
            <Setter Property="Foreground" Value="#373334"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Width" Value="350"/>
            <Setter Property="Margin" Value="0,8,0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D2AF6D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Images/carol_background.jpg" 
                        Stretch="UniformToFill"
                        Opacity="0.7"/>
        </Grid.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" 
            Orientation="Horizontal" 
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Margin="0,30,0,0">

                <Image Source="/Images/carol_logo.png" 
                       Width="150" Height="150"
                       VerticalAlignment="Center"/>

                <StackPanel VerticalAlignment="Center"
                             Margin="30,0,30,0">
                    <TextBlock Text="Restaurant Carol" 
                               FontSize="64" 
                               FontWeight="Light"
                               Foreground="#2A2A2A"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Restaurant cu specific european" 
                               FontSize="28" 
                               Foreground="#4A4A4A"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <Image Source="/Images/carol_logo.png" 
                       Width="150" Height="150"
                       VerticalAlignment="Center"/>

            </StackPanel>

            <Border Grid.Row="1" 
                    Background="#373334"
                    Opacity="0.92"
                    CornerRadius="8"
                    Width="500"
                    Margin="0,30,0,60"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="40,30,40,30">

                <StackPanel HorizontalAlignment="Center">

                    <Button Content="Acceseaza ca oaspete" 
                            Style="{StaticResource MenuButton}"
                            Click="AcceseazaCaOaspete_Click"/>

                    <Button Content="Intra in cont" 
                            Style="{StaticResource MenuButton}"
                            Click="IntraInCont_Click"/>

                    <Button Content="Inregistreaza-te" 
                            Style="{StaticResource MenuButton}"
                            Click="Inregistreaza_Click"/>

                    <TextBlock Text="Vrei sa faci parte din echipa noastra?"
                               FontSize="16"
                               Foreground="#D2AF6D"
                               HorizontalAlignment="Center"/>

                    <Button Content="Contacteaza-ne" 
                            Style="{StaticResource MenuButton}"
                            Click="Contacteaza_Click"/>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>