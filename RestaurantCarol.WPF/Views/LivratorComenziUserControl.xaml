<UserControl x:Class="RestaurantCarol.Views.LivratorComenziUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button Content="←" Background="#F4B860" Foreground="#3A3A3A" BorderThickness="0" 
                    FontSize="22" FontWeight="Bold" Width="50" Height="50" Cursor="Hand"
                    VerticalAlignment="Center"
                    Command="{Binding InapoiCommand}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="{TemplateBinding Background}" Stroke="#3A3A3A" StrokeThickness="2"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <TextBlock Text="Comenzi de livrat" FontSize="36" FontWeight="Bold" Foreground="White" Margin="20,0,0,0" VerticalAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.8"/>
                </TextBlock.Effect>
            </TextBlock>
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Text="Selecteaza o comanda (stare: a plecat la client), apoi apasa „Am ajuns” din meniul livratorului."
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="White"
                   Margin="0,15,0,25"
                   TextWrapping="Wrap">
            <TextBlock.Effect>
                <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.8"/>
            </TextBlock.Effect>
        </TextBlock>

        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="15">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>

            <Grid>
                <TextBlock Text="Nu exista comenzi in curs de livrare."
                           FontSize="16"
                           Foreground="#888888"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding VizibilitateEmpty}"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ListBox ItemsSource="{Binding Comenzi}"
                             SelectedItem="{Binding Selectata, Mode=TwoWay}"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,10"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="itemBorder"
                                                    Background="#F8F8F8"
                                                    CornerRadius="8"
                                                    Padding="15"
                                                    BorderBrush="#E0E0E0"
                                                    BorderThickness="2">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="itemBorder" Property="BorderBrush" Value="#1B7A6B"/>
                                                    <Setter TargetName="itemBorder" Property="Background" Value="#E8F5F2"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding CodComanda, StringFormat=Comanda #{0}}"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="#1B7A6B"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DataComanda, StringFormat=dd.MM.yyyy HH:mm}"
                                                   FontSize="14"
                                                   Foreground="#666666"/>
                                    </Grid>

                                    <TextBlock Margin="0,8,0,0" FontSize="14" Foreground="#444444">
                                        <Run Text="Client: "/>
                                        <Run Text="{Binding Utilizator.Nume, Mode=OneWay}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding Utilizator.Prenume, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Utilizator.Telefon, StringFormat=Telefon: {0}}"
                                               FontSize="13"
                                               Foreground="#666666"
                                               Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding AdresaLivrareCompleta, StringFormat=Adresa: {0}}"
                                               FontSize="13"
                                               Foreground="#666666"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding CostTotal, StringFormat=Total: {0} RON}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#333333"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>