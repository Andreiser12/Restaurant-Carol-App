<UserControl x:Class="RestaurantCarol.Views.ManagerComenziUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button Content="←" Background="#F4B860" Foreground="#3A3A3A" BorderThickness="0" 
                    FontSize="22" FontWeight="Bold" Width="50" Height="50" Cursor="Hand" 
                    VerticalAlignment="Center"
                    Command="{Binding InapoiCommand}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="{TemplateBinding Background}" Stroke="#3A3A3A" StrokeThickness="2"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <TextBlock Text="{Binding TitleText}" 
                       FontSize="36" FontWeight="Bold" Foreground="White" 
                       Margin="20,0,0,0" VerticalAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.8"/>
                </TextBlock.Effect>
            </TextBlock>
        </StackPanel>

        <TextBlock Grid.Row="1" 
                   Text="Apasa pe o comanda pentru a vedea detaliile si a-i schimba stadiul." 
                   FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,15,0,25">
            <TextBlock.Effect>
                <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.8"/>
            </TextBlock.Effect>
        </TextBlock>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Comenzi}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="10" Margin="0,0,0,15" Padding="15">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                            </Border.Effect>

                            <Expander HorizontalAlignment="Stretch">
                                <Expander.Header>
                                    <Grid HorizontalAlignment="Stretch" Margin="0,0,30,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto" MinWidth="150"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding CodComanda, StringFormat=Comanda #{0}}" FontSize="16" FontWeight="Bold" Foreground="#1B7A6B" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding DataComanda, StringFormat=dd.MM.yyyy HH:mm}" FontSize="14" Foreground="#555555" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding CostTotal, StringFormat={}{0} RON}" FontSize="16" FontWeight="Bold" Foreground="#333333" VerticalAlignment="Center"/>

                                        <Border Grid.Column="3" Background="#F0F0F0" CornerRadius="5" Padding="10,5,10,5" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding StareComanda}" FontSize="14" FontWeight="SemiBold" Foreground="#333333"/>
                                        </Border>
                                    </Grid>
                                </Expander.Header>

                                <Expander.Content>
                                    <Grid Margin="0,15,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                            <TextBlock Text="Date Client:" FontWeight="Bold" FontSize="14" Foreground="#333333" Margin="0,0,0,5"/>
                                            <TextBlock Text="{Binding Utilizator.Nume, StringFormat=Nume: {0}}" FontSize="13" Foreground="#666666"/>
                                            <TextBlock Text="{Binding Utilizator.Prenume, StringFormat=Prenume: {0}}" FontSize="13" Foreground="#666666"/>
                                            <TextBlock Text="{Binding Utilizator.Telefon, StringFormat=Telefon: {0}}" FontSize="13" Foreground="#666666"/>
                                            <TextBlock Text="{Binding AdresaLivrareCompleta, StringFormat=Adresa livrare: {0}}" FontSize="13" Foreground="#666666" TextWrapping="Wrap" Margin="0,0,0,15"/>

                                            <TextBlock Text="Detalii Costuri:" FontWeight="Bold" FontSize="14" Foreground="#333333" Margin="0,0,0,5"/>
                                            <TextBlock Text="{Binding CostMancare, StringFormat=Cost Mancare: {0} RON}" FontSize="13" Foreground="#666666"/>
                                            <TextBlock Text="{Binding CostTransport, StringFormat=Cost Transport: {0} RON}" FontSize="13" Foreground="#666666"/>
                                            <TextBlock Text="{Binding Discount, StringFormat=Discount aplicat: -{0} RON}" FontSize="13" Foreground="#D85A4A"/>
                                            <TextBlock Text="{Binding OraEstimataLivrare, StringFormat=Ora Estimativa Livrare: {0:HH:mm}}" FontSize="13" FontWeight="SemiBold" Foreground="#1B7A6B" Margin="0,10,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Produse comandate:" FontWeight="Bold" FontSize="14" Foreground="#333333" Margin="0,0,0,5"/>
                                            <ItemsControl ItemsSource="{Binding Items}" Margin="0,0,0,15">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock FontSize="13" Foreground="#555555" Margin="0,2,0,2">
                                                            <Run Text="{Binding Cantitate, Mode=OneWay}"/>
                                                            <Run Text="x "/>
                                                            <Run Text="{Binding DenumireAfisata, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Text="Schimba Starea:" FontWeight="Bold" FontSize="14" Foreground="#333333" Margin="0,0,0,5"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <ComboBox Grid.Column="0" 
                                                          SelectedValue="{Binding StareSelectata, Mode=TwoWay}"
                                                          ItemsSource="{Binding DataContext.StariDisponibile, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          Margin="0,0,10,0" Height="30" VerticalContentAlignment="Center"/>

                                                <Button Grid.Column="1" 
                                                        Content="Aplica" 
                                                        Command="{Binding DataContext.AplicaStareCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Background="#1B7A6B" Foreground="White" BorderThickness="0" 
                                                        Padding="15,0,15,0" Height="30" Cursor="Hand"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Expander.Content>
                            </Expander>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>