<Window x:Class="RestaurantCarol.Views.AdaugaPreparatView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adauga" 
        Height="780" Width="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="Foreground" Value="#3A3A3A"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="{TemplateBinding Background}"/>
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D0D0D0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabButtonActive" TargetType="Button" BasedOn="{StaticResource TabButton}">
            <Setter Property="Background" Value="#1B7A6B"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#444444"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,6,10,6"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="InputCombo" TargetType="ComboBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,6,10,6"/>
            <Setter Property="Height" Value="35"/>
        </Style>

        <Style x:Key="SubmitButton" TargetType="Button">
            <Setter Property="Background" Value="#1B7A6B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="25">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#155F54"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="White" 
            CornerRadius="20"
            Margin="20">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" 
                              ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>

        <Grid Margin="30,20,30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0"
                    Style="{StaticResource CloseButton}"
                    Content="✕"
                    HorizontalAlignment="Right"
                    Click="Inchide_Click"/>

            <Grid Grid.Row="1" Margin="0,10,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        x:Name="tabPreparat"
                        Style="{StaticResource TabButtonActive}"
                        Content="Adauga preparat"
                        Click="TabPreparat_Click"/>

                <Button Grid.Column="2"
                        x:Name="tabCategorie"
                        Style="{StaticResource TabButton}"
                        Content="Adauga categorie noua"
                        Click="TabCategorie_Click"/>
            </Grid>

            <ScrollViewer Grid.Row="2" 
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid>

                    <StackPanel x:Name="formPreparat" Visibility="Visible">

                        <TextBlock Text="Tip preparat" Style="{StaticResource InputLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <RadioButton x:Name="radioMancare" 
                                         Content="Mancare" 
                                         IsChecked="True"
                                         FontSize="14"
                                         Margin="0,0,20,0"
                                         Checked="TipPreparat_Changed"/>
                            <RadioButton x:Name="radioBautura" 
                                         Content="Bautura" 
                                         FontSize="14"
                                         Checked="TipPreparat_Changed"/>
                        </StackPanel>

                        <TextBlock Text="Categorie" Style="{StaticResource InputLabel}"/>
                        <ComboBox x:Name="comboCategorie"
                                  Style="{StaticResource InputCombo}"
                                  DisplayMemberPath="Denumire"/>

                        <TextBlock Text="Denumire preparat *" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="txtDenumire" Style="{StaticResource InputBox}"/>

                        <TextBlock Text="Pret (RON) *" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="txtPret" Style="{StaticResource InputBox}"/>

                        <TextBlock Text="Gramaj per portie (g) *" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="txtCantitatePortie" Style="{StaticResource InputBox}"/>

                        <TextBlock Text="Ingrediente (optional)" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="txtDescriere" 
                                 FontSize="14"
                                 Padding="10,6,10,6"
                                 Height="70"
                                 BorderBrush="#CCCCCC"
                                 BorderThickness="1"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>

                        <TextBlock Text="Alergeni" Style="{StaticResource InputLabel}"/>
                        <Border BorderBrush="#CCCCCC" BorderThickness="1" 
                                Padding="10" CornerRadius="4">
                            <ItemsControl x:Name="alergeniList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Denumire}"
                                                  Tag="{Binding IdAlergen}"
                                                  FontSize="13"
                                                  Margin="0,3,15,3"
                                                  MinWidth="120"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <TextBlock Text="Valori nutritionale (optional)" 
                                   Style="{StaticResource InputLabel}"
                                   Margin="0,15,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="Calorii (kcal)" FontSize="12" Foreground="#666"/>
                                <TextBox x:Name="txtCalorii" Style="{StaticResource InputBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="Grasimi (g)" FontSize="12" Foreground="#666"/>
                                <TextBox x:Name="txtGrasimi" Style="{StaticResource InputBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,8,0,0">
                                <TextBlock Text="Carbohidrati (g)" FontSize="12" Foreground="#666"/>
                                <TextBox x:Name="txtCarbohidrati" Style="{StaticResource InputBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,8,0,0">
                                <TextBlock Text="Proteine (g)" FontSize="12" Foreground="#666"/>
                                <TextBox x:Name="txtProteine" Style="{StaticResource InputBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,8,0,0">
                                <TextBlock Text="Sare (g)" FontSize="12" Foreground="#666"/>
                                <TextBox x:Name="txtSare" Style="{StaticResource InputBox}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Poza preparat (optional)" 
                                   Style="{StaticResource InputLabel}"
                                   Margin="0,15,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     x:Name="txtCalePoza"
                                     Style="{StaticResource InputBox}"
                                     IsReadOnly="True"
                                     Background="#F5F5F5"
                                     Text="Nicio poza selectata"/>

                            <Button Grid.Column="1"
                                    Content="Alege poza"
                                    Background="#F4B860"
                                    Foreground="#3A3A3A"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Padding="15,0,15,0"
                                    Height="35"
                                    Margin="8,0,0,0"
                                    Cursor="Hand"
                                    BorderThickness="0"
                                    Click="AlegePoza_Click"/>
                            <Button Grid.Column="2"
                                    x:Name="btnStergePoza"
                                    Content="✕"
                                    Background="#D85A4A"
                                    Foreground="White"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Width="35"
                                    Height="35"
                                    Margin="6,0,0,0"
                                    Cursor="Hand"
                                    BorderThickness="0"
                                    ToolTip="Sterge poza"
                                    Visibility="Collapsed"
                                    Click="StergePoza_Click"/>
                        </Grid>

                        <Border x:Name="previewBorder"
                                Width="200" Height="200"
                                CornerRadius="10"
                                ClipToBounds="True"
                                Margin="0,10,0,0"
                                Visibility="Collapsed"
                                HorizontalAlignment="Left">
                            <Border.Background>
                                <ImageBrush x:Name="previewImage" 
                                            Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>

                    </StackPanel>

                    <StackPanel x:Name="formCategorie" Visibility="Collapsed">

                        <TextBlock Text="Tip categorie" Style="{StaticResource InputLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <RadioButton x:Name="radioCatMancare" 
                                         Content="Mancare" 
                                         IsChecked="True"
                                         FontSize="14"
                                         Margin="0,0,20,0"/>
                            <RadioButton x:Name="radioCatBautura" 
                                         Content="Bautura" 
                                         FontSize="14"/>
                        </StackPanel>

                        <TextBlock Text="Denumire categorie *" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="txtCatDenumire" Style="{StaticResource InputBox}"/>

                        <Border Background="#FFF8E1"
                                CornerRadius="6"
                                Padding="15,10,15,10"
                                Margin="0,20,0,0">
                            <TextBlock Text="Categoria va fi creata goala. Poti adauga preparate in ea ulterior, din tab-ul 'Adauga preparat'."
                                       FontSize="13"
                                       FontStyle="Italic"
                                       Foreground="#8B6914"
                                       TextWrapping="Wrap"/>
                        </Border>

                    </StackPanel>

                </Grid>
            </ScrollViewer>

            <StackPanel Grid.Row="3" Margin="0,15,0,0">
                <Button x:Name="btnSubmit"
            Style="{StaticResource SubmitButton}"
            Content="Adauga preparat"
            Click="Submit_Click"/>

                <Button x:Name="btnSterge"
            Background="Transparent"
            Foreground="#D85A4A"
            BorderBrush="#D85A4A"
            BorderThickness="1"
            FontSize="14"
            FontWeight="SemiBold"
            Height="42"
            Cursor="Hand"
            Margin="0,10,0,0"
            Content="Sterge preparat"
            Visibility="Collapsed"
            Click="Sterge_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="21">
                                <ContentPresenter HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFE5E0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

        </Grid>
    </Border>
</Window>