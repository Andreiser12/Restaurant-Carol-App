<Window x:Class="RestaurantCarol.Views.DetaliuPreparatView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalii Preparat" 
        Height="750" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#D2AF6D"/>
            <Setter Property="Foreground" Value="#373334"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="{TemplateBinding Background}"/>
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D2AF6D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="QuantityButton" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#373334"/>
            <Setter Property="Foreground" Value="#D2AF6D"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="{TemplateBinding Background}"/>
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D2AF6D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AlergenBadge" TargetType="Border">
            <Setter Property="Background" Value="#373334"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,5,10,5"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="BorderBrush" Value="#D2AF6D"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#D2AF6D" 
                                CornerRadius="4"
                                Margin="2,0,2,0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1" 
                                       Name="PART_VerticalScrollBar"
                                       Style="{StaticResource CustomScrollBar}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#373334" 
            CornerRadius="20"
            Margin="20">
        <Border.Effect>
            <DropShadowEffect Color="Black" 
                              BlurRadius="20" 
                              ShadowDepth="0" 
                              Opacity="0.3"/>
        </Border.Effect>

        <Grid Margin="30,20,30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0"
                    Style="{StaticResource CloseButton}"
                    Content="✕"
                    HorizontalAlignment="Right"
                    Click="Inchide_Click"/>

            <ScrollViewer Grid.Row="1" 
                          Style="{StaticResource CustomScrollViewer}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,5,0,15">
                <StackPanel>

                    <Border Width="280" Height="280" 
                            CornerRadius="140"
                            ClipToBounds="True"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20">
                        <Border.Background>
                            <ImageBrush x:Name="pozaPreparat" 
                                        Stretch="UniformToFill"/>
                        </Border.Background>
                    </Border>

                    <TextBlock x:Name="denumireText"
                               Text="Denumire preparat"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#D2AF6D"
                               HorizontalAlignment="Left"/>

                    <TextBlock x:Name="pretText"
                               Text="0.00 RON"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#D2AF6D"
                               Margin="0,5,0,2"/>

                    <TextBlock x:Name="cantitatePortieText"
                               Text="0g"
                               FontSize="16"
                               Foreground="#D2AF6D"
                               Margin="0,0,0,10"/>

                    <Border Height="1" 
                            Background="#D2AF6D" 
                            Margin="0,10,0,15"/>

                    <StackPanel x:Name="ingredienteSection" Margin="0,0,0,15">
                        <TextBlock Text="Ingrediente"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#D2AF6D"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="descriereText"
                                   Text="Descriere preparat..."
                                   FontSize="14"
                                   Foreground="#D2AF6D"
                                   TextWrapping="Wrap"
                                   LineHeight="20"/>
                    </StackPanel>

                    <StackPanel x:Name="alergeniSection" Margin="0,0,0,15">
                        <TextBlock Text="Alergeni"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#D2AF6D"
                                   Margin="0,0,0,8"/>
                        <ItemsControl x:Name="alergeniList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource AlergenBadge}">
                                        <TextBlock Text="{Binding Denumire}" 
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#D2AF6D"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel x:Name="valoriSection" Margin="0,0,0,15">
                        <TextBlock Text="Valori nutriționale"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#D2AF6D"
                                   Margin="0,0,0,8"/>
                        <StackPanel x:Name="valoriList">
                            <StackPanel.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#D2AF6D"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Margin" Value="0,2,0,2"/>
                                </Style>
                            </StackPanel.Resources>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" 
                        x:Name="cosSection"
                        Margin="0,10,0,0">

                <Border Background="#D2AF6D"
                        CornerRadius="20"
                        Padding="8,4,8,4"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource QuantityButton}"
                                Content="−"
                                Click="Minus_Click"/>
                        <TextBlock x:Name="cantitateText"
                                   Text="1"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#373334"
                                   VerticalAlignment="Center"
                                   Margin="20,0,20,0"/>
                        <Button Style="{StaticResource QuantityButton}"
                                Content="+"
                                Click="Plus_Click"/>
                    </StackPanel>
                </Border>

                <Button x:Name="adaugaButton"
                        Background="#D2AF6D"
                        Foreground="#373334"
                        FontSize="16"
                        FontWeight="Bold"
                        Height="55"
                        Cursor="Hand"
                        BorderThickness="0"
                        Click="Adauga_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="30">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E0A050"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock x:Name="adaugaText" Text="Adaugă în coș - 0.00 RON"/>
                </Button>

                <Border x:Name="oaspeteSection"
                        Visibility="Collapsed"
                        Background="#D2AF6D"
                        CornerRadius="12"
                        Padding="20,15,20,15"
                        BorderBrush="#D2AF6D"
                        BorderThickness="1">
                    <TextBlock Text="Logheaza-te pentru a comanda"
                               FontSize="16"
                               Foreground="#373334"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>

        </Grid>
    </Border>
</Window>