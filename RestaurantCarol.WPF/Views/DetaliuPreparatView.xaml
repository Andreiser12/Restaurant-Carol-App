<Window x:Class="RestaurantCarol.Views.DetaliuPreparatView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalii Preparat" 
        Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Background="#F8F4ED">
        <StackPanel VerticalAlignment="Center" 
                    HorizontalAlignment="Center">

            <TextBlock x:Name="denumireText"
                       Text="Detalii preparat"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="#3A3A3A"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="(popup gol — implementare ulterioara)"
                       FontSize="14"
                       FontStyle="Italic"
                       Foreground="#888888"
                       HorizontalAlignment="Center"
                       Margin="0,15,0,0"/>

            <Button Content="Inchide" 
                    Width="150" Height="40"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Background="#F4B860"
                    Foreground="#3A3A3A"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,30,0,0"
                    Click="Inchide_Click"/>

        </StackPanel>
    </Grid>
</Window>