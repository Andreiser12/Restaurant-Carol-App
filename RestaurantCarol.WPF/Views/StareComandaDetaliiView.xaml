<Window x:Class="RestaurantCarol.Views.StareComandaDetaliiView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalii comanda"
        Height="480" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True">

    <Border Background="White" CornerRadius="12" Padding="24" Margin="12">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.25"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <TextBlock x:Name="titleText" FontSize="20" FontWeight="Bold" Foreground="#1B7A6B"/>
                <Button Content="✕" HorizontalAlignment="Right" Width="36" Height="36"
                        Background="#F4B860" Foreground="#3A3A3A" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="Inchide_Click"/>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,12,0,0">
                <TextBlock x:Name="dataText" FontSize="13" Foreground="#666666"/>
                <TextBlock x:Name="oraText" FontSize="13" Foreground="#666666" Margin="0,2,0,0"/>
                <TextBlock x:Name="totalText" FontSize="14" FontWeight="SemiBold" Foreground="#333333" Margin="0,6,0,0"/>
            </StackPanel>

            <TextBlock Grid.Row="2" Text="Produse:" FontWeight="Bold" FontSize="14" Foreground="#333333" Margin="0,16,0,8"/>
            <ScrollViewer Grid.Row="3" MaxHeight="100" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="produseList"/>
            </ScrollViewer>

            <StackPanel Grid.Row="4" Margin="0,20,0,0">
                <TextBlock Text="Starea comenzii" FontWeight="Bold" FontSize="14" Foreground="#333333" Margin="0,0,0,10"/>
                <TextBlock x:Name="anulataText" Text="Comanda a fost anulata."
                           Foreground="#D85A4A" FontWeight="SemiBold" Margin="0,0,0,8" Visibility="Collapsed"/>

                <UniformGrid x:Name="stariPanel" Rows="1" Columns="4" Margin="0,0,0,4">
                    <StackPanel Margin="4" HorizontalAlignment="Center">
                        <CheckBox x:Name="chkInregistrata" IsEnabled="False" HorizontalAlignment="Center"/>
                        <TextBlock Text="Inregistrata" FontSize="11" TextAlignment="Center" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        <TextBlock Text="finala" FontSize="9" Foreground="#AAAAAA" HorizontalAlignment="Center" Visibility="Collapsed"/>
                    </StackPanel>
                    <StackPanel Margin="4" HorizontalAlignment="Center">
                        <CheckBox x:Name="chkSePregateste" IsEnabled="False" HorizontalAlignment="Center"/>
                        <TextBlock Text="Se pregateste" FontSize="11" TextAlignment="Center" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        <TextBlock Text="finala" FontSize="9" Foreground="#AAAAAA" HorizontalAlignment="Center" Visibility="Collapsed"/>
                    </StackPanel>
                    <StackPanel Margin="4" HorizontalAlignment="Center">
                        <CheckBox x:Name="chkAPlecat" IsEnabled="False" HorizontalAlignment="Center"/>
                        <TextBlock Text="A plecat" FontSize="11" TextAlignment="Center" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        <TextBlock Text="finala" FontSize="9" Foreground="#AAAAAA" HorizontalAlignment="Center" Visibility="Collapsed"/>
                    </StackPanel>
                    <StackPanel Margin="4" HorizontalAlignment="Center">
                        <CheckBox x:Name="chkLivrata" IsEnabled="False" HorizontalAlignment="Center"/>
                        <TextBlock Text="Livrata" FontSize="11" TextAlignment="Center" Margin="0,4,0,0"/>
                        <TextBlock Text="finala" FontSize="9" Foreground="#1B7A6B" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </UniformGrid>

                <TextBlock FontSize="11" Foreground="#888888" TextAlignment="Center"
                           Text="Bifarea indica pasul atins. „Livrata” este stare finala."/>
            </StackPanel>

            <Button x:Name="btnAnuleaza" Grid.Row="5" Content="Anuleaza comanda"
                    Margin="0,20,0,0" Height="42" Background="#D85A4A" Foreground="White"
                    FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Click="Anuleaza_Click"/>
        </Grid>
    </Border>
</Window>
