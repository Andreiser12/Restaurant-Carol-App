<Window x:Class="RestaurantCarol.Views.AngajatHubView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Restaurant Carol - Personal" 
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Images/interior_background.jpg" 
                        Stretch="UniformToFill"
                        Opacity="0.7"/>
        </Grid.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
                    Background="#EB3A3A3A"
                    Height="110">
                <Grid Margin="20,0,20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="1" 
                            Background="#EB7A6B14"
                            CornerRadius="6"
                            Padding="30,12,30,12"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="welcomeText"
                                   Text="Restaurant Carol - Personal"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <Border Grid.Column="2"
                            x:Name="prenumeBorder"
                            Background="#EB7A6B14"
                            CornerRadius="6"
                            Padding="20,12,20,12"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Cursor="Hand"
                            MouseLeftButtonDown="Prenume_Click">
                        <TextBlock x:Name="prenumeText"
                                   Text="Angajat"
                                   FontSize="18"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="40,20,40,40">
                <ContentControl x:Name="contentArea"/>
            </Grid>
        </Grid>
    </Grid>
</Window>