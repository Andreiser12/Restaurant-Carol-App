<Window x:Class="RestaurantCarol.Views.AngajatHubView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Restaurant Carol - Personal" 
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Images/interior_background.jpg" 
                        Stretch="UniformToFill"
                        Opacity="0.7"/>
        </Grid.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
                    Background="#EB3A3A3A"
                    Height="110">
                <Grid Margin="20,0,20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="1" 
                            Background="#EB7A6B14"
                            CornerRadius="6"
                            Padding="30,12,30,12"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding WelcomeText}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <Grid Grid.Column="2"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center">
                        <Border x:Name="prenumeBorder"
                                Background="#EB7A6B14"
                                CornerRadius="6"
                                Padding="20,12,20,12"
                                Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" 
                                              Command="{Binding PrenumeCommand}"/>
                            </Border.InputBindings>
                            <TextBlock Text="{Binding PrenumeText}"
                                       FontSize="18"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <Popup IsOpen="{Binding PopupPrenumeDeschis, Mode=TwoWay}"
                               PlacementTarget="{Binding ElementName=prenumeBorder}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               PopupAnimation="Fade">
                            <Border Background="White"
                                    CornerRadius="8"
                                    Margin="5,8,5,8"
                                    MinWidth="160">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="15"
                                                      ShadowDepth="0" Opacity="0.3"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Button Content="Iesire din cont"
                                            Background="Transparent"
                                            Foreground="#D85A4A"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            BorderThickness="0"
                                            Padding="20,12,20,12"
                                            HorizontalContentAlignment="Left"
                                            Cursor="Hand"
                                            Command="{Binding LogoutCommand}"/>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="40,20,40,40">
                <ContentControl x:Name="contentArea"/>
            </Grid>
        </Grid>
    </Grid>
</Window>