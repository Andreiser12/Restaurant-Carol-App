<Window x:Class="RestaurantCarol.Views.AdaugaMeniuView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adauga meniu" Height="550" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" Background="Transparent" AllowsTransparency="True">

    <Border Background="White" CornerRadius="12" Padding="24" Margin="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Adauga meniu compus" FontSize="20" FontWeight="Bold" Foreground="#1B7A6B"/>

            <StackPanel Grid.Row="1" Margin="0,16,0,0">
                <TextBlock Text="Denumire" FontWeight="SemiBold"/>
                <TextBox Margin="0,4,0,12"
                         Text="{Binding Denumire, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Categorie" FontWeight="SemiBold"/>
                <ComboBox DisplayMemberPath="Denumire" 
                          Margin="0,4,0,12"
                          ItemsSource="{Binding Categorii}"
                          SelectedItem="{Binding CategorieSelectata, Mode=TwoWay}"/>

                <TextBlock Text="Selecteaza preparate pentru meniu" FontWeight="SemiBold" TextWrapping="Wrap"/>
                <ScrollViewer MaxHeight="260" Margin="0,8,0,0">
                    <ItemsControl ItemsSource="{Binding Preparate}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                    <CheckBox Content="{Binding Denumire}"
                                              IsChecked="{Binding IsBifat, Mode=TwoWay}"
                                              VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Anuleaza" 
                        Command="{Binding AnuleazaCommand}"
                        Margin="0,0,8,0" Padding="16,8"/>
                <Button Content="Salveaza" 
                        Command="{Binding SalveazaCommand}"
                        Background="#1B7A6B" Foreground="White" Padding="16,8" BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>