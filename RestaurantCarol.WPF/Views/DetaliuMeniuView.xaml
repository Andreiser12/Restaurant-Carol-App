<Window x:Class="RestaurantCarol.Views.DetaliuMeniuView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalii Meniu" Height="600" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" Background="Transparent" AllowsTransparency="True">

    <Border Background="#373334" CornerRadius="12" Padding="24" Margin="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <TextBlock Text="{Binding Denumire}" FontSize="22" FontWeight="Bold" Foreground="#D2AF6D"/>
                <Button Content="✕" HorizontalAlignment="Right" Command="{Binding InchideCommand}"
                        Width="36" Height="36" Background="#D2AF6D" Foreground="#373334" BorderThickness="0"/>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,16,0,0">
                <Border Height="180" CornerRadius="8" Margin="0,0,0,12">
                    <Border.Background>
                        <ImageBrush ImageSource="/Images/carol_logo.png" Stretch="UniformToFill"/>
                    </Border.Background>
                </Border>
                <TextBlock Text="{Binding PretText}" FontSize="18" Foreground="White" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding GramajeText}" FontSize="13" Foreground="#D2AF6D" TextWrapping="Wrap" Margin="0,8,0,0"/>
                <TextBlock x:Name="indisponibilText" Text="indisponibil" Foreground="#D85A4A" FontWeight="Bold" Margin="0,8,0,0" Visibility="Collapsed"/>
            </StackPanel>

            <StackPanel x:Name="cosSection" Grid.Row="2" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,8">
                    <Button Content="-" Command="{Binding MinusCommand}" Width="36" Height="36" Margin="8"/>
                    <TextBlock Text="{Binding Cantitate}" FontSize="20" Foreground="White" VerticalAlignment="Center" Margin="12,0"/>
                    <Button Content="+" Command="{Binding PlusCommand}" Width="36" Height="36" Margin="8"/>
                </StackPanel>
                <Button Content="{Binding AdaugaText}" Command="{Binding AdaugaCommand}"
                        Background="#D2AF6D" Foreground="#373334" FontWeight="Bold"
                        Padding="16,10" BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
