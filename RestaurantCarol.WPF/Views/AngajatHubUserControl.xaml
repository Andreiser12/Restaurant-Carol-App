<UserControl x:Class="RestaurantCarol.Views.AngajatHubUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="RolCircle" TargetType="Button">
            <Setter Property="Width" Value="280"/>
            <Setter Property="Height" Value="280"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="ellipse"
                                     Stroke="#3A3A3A" 
                                     StrokeThickness="3"/>
                            <ContentPresenter HorizontalAlignment="Stretch" 
                                              VerticalAlignment="Stretch"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ellipse" Property="Opacity" Value="0.8"/>
                                <Setter TargetName="ellipse" Property="StrokeThickness" Value="5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ellipse" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UniformGrid Rows="1" Columns="3"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Center"
                 Margin="50,0,50,0">

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button x:Name="bucatarButton"
                    Style="{StaticResource RolCircle}"
                    Click="Bucatar_Click">
                <Border Width="280" Height="280" 
                        CornerRadius="140"
                        ClipToBounds="True">
                    <Border.Background>
                        <ImageBrush x:Name="bucatarImage" 
                                    ImageSource="/Images/carol_logo.png" 
                                    Stretch="UniformToFill"/>
                    </Border.Background>
                </Border>
            </Button>
            <TextBlock Text="Bucatar" 
                       TextAlignment="Center"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Margin="0,15,0,0"
                       HorizontalAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="8" 
                                      ShadowDepth="2" Opacity="0.8"/>
                </TextBlock.Effect>
            </TextBlock>
        </StackPanel>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button x:Name="managerButton"
                    Style="{StaticResource RolCircle}"
                    Click="Manager_Click">
                <Border Width="280" Height="280" 
                        CornerRadius="140"
                        ClipToBounds="True">
                    <Border.Background>
                        <ImageBrush x:Name="managerImage" 
                                    ImageSource="/Images/carol_logo.png" 
                                    Stretch="UniformToFill"/>
                    </Border.Background>
                </Border>
            </Button>
            <TextBlock Text="Manager" 
                       TextAlignment="Center"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Margin="0,15,0,0"
                       HorizontalAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="8" 
                                      ShadowDepth="2" Opacity="0.8"/>
                </TextBlock.Effect>
            </TextBlock>
        </StackPanel>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button x:Name="livratorButton"
                    Style="{StaticResource RolCircle}"
                    Click="Livrator_Click">
                <Border Width="280" Height="280" 
                        CornerRadius="140"
                        ClipToBounds="True">
                    <Border.Background>
                        <ImageBrush x:Name="livratorImage" 
                                    ImageSource="/Images/carol_logo.png" 
                                    Stretch="UniformToFill"/>
                    </Border.Background>
                </Border>
            </Button>
            <TextBlock Text="Livrator" 
                       TextAlignment="Center"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Margin="0,15,0,0"
                       HorizontalAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="8" 
                                      ShadowDepth="2" Opacity="0.8"/>
                </TextBlock.Effect>
            </TextBlock>
        </StackPanel>

    </UniformGrid>
</UserControl>