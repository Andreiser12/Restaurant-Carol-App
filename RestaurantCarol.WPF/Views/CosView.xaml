<Window x:Class="RestaurantCarol.Views.CosView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cosul tau" 
        Height="700" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#F4B860"/>
            <Setter Property="Foreground" Value="#3A3A3A"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="{TemplateBinding Background}"/>
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0A050"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SmallRoundButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="#F4B860"/>
            <Setter Property="Foreground" Value="#3A3A3A"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="{TemplateBinding Background}"/>
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0A050"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="White" 
            CornerRadius="20"
            Margin="20">
        <Border.Effect>
            <DropShadowEffect Color="Black" 
                              BlurRadius="20" 
                              ShadowDepth="0" 
                              Opacity="0.3"/>
        </Border.Effect>

        <Grid Margin="30,20,30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="Cosul tau"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#1A1A1A"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"/>
                <Button Style="{StaticResource CloseButton}"
                        Content="✕"
                        HorizontalAlignment="Right"
                        Click="Inchide_Click"/>
            </Grid>

            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="itemsList"
                              ItemsSource="{Binding}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FDF1DC"
                                    CornerRadius="12"
                                    Padding="12,10,12,10"
                                    Margin="0,5,0,5"
                                    BorderBrush="#F4B860"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="60" Height="60"
                                            CornerRadius="30"
                                            ClipToBounds="True"
                                            VerticalAlignment="Center">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding CalePoza, FallbackValue='/Images/carol_logo.png', TargetNullValue='/Images/carol_logo.png'}" 
                                                        Stretch="UniformToFill"/>
                                        </Border.Background>
                                    </Border>

                                    <StackPanel Grid.Column="1" 
                                                VerticalAlignment="Center"
                                                Margin="12,0,12,0">
                                        <TextBlock Text="{Binding Denumire}" 
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="#1A1A1A"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock FontSize="12"
                                                   Foreground="#666666">
                                            <Run Text="{Binding PretUnitar, Mode=OneWay, StringFormat={}{0:F2}}"/>
                                            <Run Text="RON / portie"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" 
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Style="{StaticResource SmallRoundButton}"
                                                Content="−"
                                                Tag="{Binding}"
                                                Click="Minus_Click"/>
                                        <TextBlock Text="{Binding Cantitate}" 
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,8,0"
                                                   MinWidth="20"
                                                   TextAlignment="Center"/>
                                        <Button Style="{StaticResource SmallRoundButton}"
                                                Content="+"
                                                Tag="{Binding}"
                                                Click="Plus_Click"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" 
                                                VerticalAlignment="Center"
                                                Margin="15,0,0,0">
                                        <TextBlock FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="#1A1A1A"
                                                   HorizontalAlignment="Right">
                                            <Run Text="{Binding Subtotal, Mode=OneWay, StringFormat={}{0:F2}}"/>
                                            <Run Text="RON"/>
                                        </TextBlock>
                                        <Button Style="{StaticResource SmallRoundButton}"
                                                Content="✕"
                                                Background="#D85A4A"
                                                Foreground="White"
                                                Tag="{Binding}"
                                                Click="Sterge_Click"
                                                Margin="0,5,0,0"
                                                HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock x:Name="cosGolText"
                       Grid.Row="1"
                       Text="Cosul tau este gol"
                       FontSize="16"
                       FontStyle="Italic"
                       Foreground="#888888"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Collapsed"/>

            <StackPanel Grid.Row="2" Margin="0,15,0,0">

                <Border Height="1" 
            Background="#E0E0E0" 
            Margin="0,0,0,15"/>

                <StackPanel x:Name="adresaSection" Margin="0,0,0,15">
                    <TextBlock Text="Adresa de livrare:"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Foreground="#444444"
                   Margin="0,0,0,5"/>

                    <ComboBox x:Name="adreseComboBox"
                  FontSize="13"
                  Padding="10,8,10,8"
                  Background="#FDF1DC"
                  BorderBrush="#F4B860"
                  BorderThickness="1"
                  DisplayMemberPath="AdresaText"
                  SelectedValuePath="IdAdresa"/>

                    <Border x:Name="fariAdresaText"
                Visibility="Collapsed"
                Background="#FDF1DC"
                CornerRadius="6"
                Padding="12,10,12,10"
                BorderBrush="#F4B860"
                BorderThickness="1">
                        <TextBlock Text="Nu ai nicio adresa salvata. Click pe panoul ADRESA din meniu pentru a adauga."
                       FontSize="12"
                       FontStyle="Italic"
                       Foreground="#7A6B14"
                       TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>

                <Grid Margin="0,0,0,15">
                    <TextBlock Text="Total"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="#1A1A1A"
                   HorizontalAlignment="Left"/>
                    <TextBlock x:Name="totalText"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#1A1A1A"
                   HorizontalAlignment="Right"/>
                </Grid>

                <Button x:Name="plaseazaButton"
            Background="#F4B860"
            Foreground="#3A3A3A"
            FontSize="16"
            FontWeight="Bold"
            Height="55"
            Cursor="Hand"
            BorderThickness="0"
            Click="Plaseaza_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                        CornerRadius="30">
                                <ContentPresenter HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E0A050"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="Plaseaza comanda"/>
                </Button>
            </StackPanel>

        </Grid>
    </Border>
</Window>